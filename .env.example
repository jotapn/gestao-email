# ============================================================
# DJANGO / APLICACAO
# Ajuste os dominios para o ambiente real.
# Em producao, mantenha DEBUG=False.
# ============================================================
SECRET_KEY=troque-por-uma-chave-segura
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,seu-dominio.com.br
CSRF_TRUSTED_ORIGINS=https://seu-dominio.com.br
REQUEST_TIMEOUT=30

# ============================================================
# SEGURANCA HTTP
# Recomendado para deploy atras de HTTPS/proxy reverso.
# ============================================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# ============================================================
# BANCO DE DADOS
# Use sqlite para desenvolvimento ou deploy simples.
# Para MySQL, troque DB_ENGINE para mysql e preencha os campos abaixo.
# ============================================================
DB_ENGINE=sqlite
SQLITE_PATH=/app/data/db.sqlite3
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASSWORD=senha_do_banco
DB_HOST=127.0.0.1
DB_PORT=3306

# ============================================================
# WHM
# Modo recomendado quando houver acesso ao WHM.
# ============================================================
WHM_HOST=https://seu-whm.com:2087
WHM_USER=root
WHM_TOKEN=seu_token_whm
WHM_VERIFY_SSL=True
HIDDEN_CPANEL_DOMAINS=dominio-interno.com.br,outro-dominio.com.br

# ============================================================
# CPANEL DIRETO
# Fallback para gerenciamento de uma unica conta.
# ============================================================
CPANEL_HOST=https://seu-cpanel.com:2083
CPANEL_USER=usuario_cpanel
CPANEL_TOKEN=seu_token_uapi
CPANEL_DOMAIN=seudominio.com.br
CPANEL_VERIFY_SSL=True

# ============================================================
# SMTP / NOTIFICACOES
# Use console backend em desenvolvimento, SMTP em producao.
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seudominio.com.br
EMAIL_PORT=465
EMAIL_HOST_USER=usuario@seudominio.com.br
EMAIL_HOST_PASSWORD=sua_senha_smtp
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
DEFAULT_FROM_EMAIL=usuario@seudominio.com.br

# ============================================================
# GOOGLE WORKSPACE
# O arquivo da service account deve existir no caminho informado.
# ============================================================
GOOGLE_WORKSPACE_DOMAIN=seudominio.com.br
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@seudominio.com.br
GOOGLE_SERVICE_ACCOUNT_FILE=assets/service_account.json
GOOGLE_WORKSPACE_DEFAULT_ORG_UNIT=
GOOGLE_WORKSPACE_LICENSING_ENABLED=False
GOOGLE_WORKSPACE_PRODUCT_ID=
GOOGLE_WORKSPACE_SKU_ID=
